    {
      "id": "t_linux", "type": "text", "x": 60, "y": 256, "width": 230, "height": 325,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "a3a", "roundness": null,
      "seed": 4003, "version": 1, "versionNonce": 4004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "Sockets:\n  AF_UNIX SOCK_SEQPACKET\n  Abstract namespace \\0aether_*\n  MSG_NOSIGNAL on send()\n\nShared Memory:\n  memfd_create()\n  mmap(MAP_SHARED)\n  Zero-filled by kernel\n\nFD Passing:\n  sendmsg() + SCM_RIGHTS\n  recvmsg() + CMSG\n\nSignaling:\n  send(fd, 1 byte)\n  recv(fd, 1 byte)\n\nPeer Auth:\n  SO_PEERCRED → uid\n  geteuid() comparison",
      "originalText": "Sockets:\n  AF_UNIX SOCK_SEQPACKET\n  Abstract namespace \\0aether_*\n  MSG_NOSIGNAL on send()\n\nShared Memory:\n  memfd_create()\n  mmap(MAP_SHARED)\n  Zero-filled by kernel\n\nFD Passing:\n  sendmsg() + SCM_RIGHTS\n  recvmsg() + CMSG\n\nSignaling:\n  send(fd, 1 byte)\n  recv(fd, 1 byte)\n\nPeer Auth:\n  SO_PEERCRED → uid\n  geteuid() comparison",
      "autoResize": true, "fontSize": 12, "fontFamily": 3, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "linux_detail", "lineHeight": 1.25
    },

