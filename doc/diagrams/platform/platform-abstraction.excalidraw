    },
    {
      "id": "t_mac", "type": "text", "x": 345, "y": 256, "width": 230, "height": 325,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "a5a", "roundness": null,
      "seed": 6003, "version": 1, "versionNonce": 6004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "Sockets:\n  AF_UNIX SOCK_STREAM\n  Pathname /tmp/aether_*\n  SO_NOSIGPIPE on socket\n\nShared Memory:\n  shm_open() + ftruncate()\n  mmap(MAP_SHARED)\n  Explicit zero-fill\n\nFD Passing:\n  sendmsg() + SCM_RIGHTS\n  recvmsg() + CMSG\n  (same as Linux)\n\nSignaling:\n  send(fd, 1 byte)\n  recv(fd, 1 byte)\n\nPeer Auth:\n  LOCAL_PEERPID → pid\n  getpwuid() for uid",
      "originalText": "Sockets:\n  AF_UNIX SOCK_STREAM\n  Pathname /tmp/aether_*\n  SO_NOSIGPIPE on socket\n\nShared Memory:\n  shm_open() + ftruncate()\n  mmap(MAP_SHARED)\n  Explicit zero-fill\n\nFD Passing:\n  sendmsg() + SCM_RIGHTS\n  recvmsg() + CMSG\n  (same as Linux)\n\nSignaling:\n  send(fd, 1 byte)\n  recv(fd, 1 byte)\n\nPeer Auth:\n  LOCAL_PEERPID → pid\n  getpwuid() for uid",
      "autoResize": true, "fontSize": 12, "fontFamily": 3, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "mac_detail", "lineHeight": 1.25
    },

