    {
      "id": "t_win", "type": "text", "x": 630, "y": 256, "width": 230, "height": 325,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "a7a", "roundness": null,
      "seed": 8003, "version": 1, "versionNonce": 8004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "Sockets (Named Pipes):\n  CreateNamedPipe()\n  \\\\.\\pipe\\aether_*\n  FILE_FLAG_OVERLAPPED\n\nShared Memory:\n  CreateFileMapping()\n  MapViewOfFile()\n  Zero-filled by kernel\n\nHandle Passing:\n  DuplicateHandle()\n  Send handle value as data\n  (no SCM_RIGHTS equiv)\n\nSignaling:\n  WriteFile(pipe, 1 byte)\n  ReadFile(pipe, 1 byte)\n\nPeer Auth:\n  GetNamedPipeClientProcessId()\n  OpenProcessToken() → uid",
      "originalText": "Sockets (Named Pipes):\n  CreateNamedPipe()\n  \\\\.\\pipe\\aether_*\n  FILE_FLAG_OVERLAPPED\n\nShared Memory:\n  CreateFileMapping()\n  MapViewOfFile()\n  Zero-filled by kernel\n\nHandle Passing:\n  DuplicateHandle()\n  Send handle value as data\n  (no SCM_RIGHTS equiv)\n\nSignaling:\n  WriteFile(pipe, 1 byte)\n  ReadFile(pipe, 1 byte)\n\nPeer Auth:\n  GetNamedPipeClientProcessId()\n  OpenProcessToken() → uid",
      "autoResize": true, "fontSize": 12, "fontFamily": 3, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "win_detail", "lineHeight": 1.25
    }
