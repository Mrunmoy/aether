      "seed": 5003, "version": 1, "versionNonce": 5004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "onAcceptReady()  // RunLoop fires this\nacceptClient() → handshake → Connection\nloop->addSource(clientFd, onClientReady,\n                          onClientError)\n// no receiver thread per client!",
      "originalText": "onAcceptReady()  // RunLoop fires this\nacceptClient() → handshake → Connection\nloop->addSource(clientFd, onClientReady,\n                          onClientError)\n// no receiver thread per client!",
      "autoResize": true, "fontSize": 11, "fontFamily": 3, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "svc_accept", "lineHeight": 1.25
    },

    {
