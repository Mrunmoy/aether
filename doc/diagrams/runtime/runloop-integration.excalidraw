    {
      "id": "t_ready", "type": "text", "x": 65, "y": 408, "width": 330, "height": 65,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "a5a", "roundness": null,
      "seed": 6003, "version": 1, "versionNonce": 6004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "onClientReady(client)  // RunLoop fires this\nlock(handlerMutex)  // guards against stop()\nrecvSignal() → readFrame(rxRing)\nonRequest() → handleFoo()\nsendResponse(txRing) under sendMutex",
      "originalText": "onClientReady(client)  // RunLoop fires this\nlock(handlerMutex)  // guards against stop()\nrecvSignal() → readFrame(rxRing)\nonRequest() → handleFoo()\nsendResponse(txRing) under sendMutex",
      "autoResize": true, "fontSize": 11, "fontFamily": 3, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "svc_ready", "lineHeight": 1.25
    },

