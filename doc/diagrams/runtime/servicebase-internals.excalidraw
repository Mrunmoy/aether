    {
      "id": "text_rl_stop", "type": "text", "x": 545, "y": 550, "width": 330, "height": 80,
      "angle": 0, "strokeColor": "#c92a2a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "aAa", "roundness": null,
      "seed": 11003, "version": 1, "versionNonce": 11004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "stop() — shutdown sequence\n1. m_running = false\n2. removeSource(listenFd)\n3. for each client: removeSource(fd) → close()\n4. loop.stop() or join threads",
      "originalText": "stop() — shutdown sequence\n1. m_running = false\n2. removeSource(listenFd)\n3. for each client: removeSource(fd) → close()\n4. loop.stop() or join threads",
      "autoResize": true, "fontSize": 12, "fontFamily": 2, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "rl_stop", "lineHeight": 1.25
    },

