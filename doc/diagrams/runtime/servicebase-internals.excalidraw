    },
    {
      "id": "text_rl_loop", "type": "text", "x": 545, "y": 130, "width": 330, "height": 60,
      "angle": 0, "strokeColor": "#862e9c", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "a6a", "roundness": null,
      "seed": 7003, "version": 1, "versionNonce": 7004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "RunLoop (single thread)\naddSource(listenFd) → onAcceptReady()\naddSource(clientFd) → onClientReady()",
      "originalText": "RunLoop (single thread)\naddSource(listenFd) → onAcceptReady()\naddSource(clientFd) → onClientReady()",
      "autoResize": true, "fontSize": 13, "fontFamily": 2, "textAlign": "center",
      "verticalAlign": "middle", "containerId": "rl_loop", "lineHeight": 1.25
    },

