      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "aC",
      "roundness": {"type": 3}, "seed": 13001, "version": 1, "versionNonce": 13002,
      "isDeleted": false, "boundElements": [{"id": "tf_payload", "type": "text"}],
      "updated": 1774700000000, "link": null, "locked": false
    },
    {
      "id": "tf_payload", "type": "text", "x": 45, "y": 378, "width": 770, "height": 65,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "aCa", "roundness": null,
      "seed": 13003, "version": 1, "versionNonce": 13004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "Payload (payloadBytes length, variable)\n\nPOD structs only — fixed-size fields packed sequentially. No alignment padding, no pointers, no std::string.\nArrays: T[N] written as N contiguous elements.  Strings: char[N+1] null-terminated, fixed size on wire.",
      "originalText": "Payload (payloadBytes length, variable)\n\nPOD structs only — fixed-size fields packed sequentially. No alignment padding, no pointers, no std::string.\nArrays: T[N] written as N contiguous elements.  Strings: char[N+1] null-terminated, fixed size on wire.",
      "autoResize": true, "fontSize": 12, "fontFamily": 2, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "payload_box", "lineHeight": 1.25
    },

    {
      "id": "ring_note", "type": "rectangle", "x": 40, "y": 480, "width": 780, "height": 60,
      "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "#edf2ff",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "aD",
      "roundness": {"type": 3}, "seed": 14001, "version": 1, "versionNonce": 14002,
      "isDeleted": false, "boundElements": [{"id": "tf_ring", "type": "text"}],
      "updated": 1774700000000, "link": null, "locked": false
    },
    {
      "id": "tf_ring", "type": "text", "x": 45, "y": 488, "width": 770, "height": 45,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "aDa", "roundness": null,
      "seed": 14003, "version": 1, "versionNonce": 14004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "writeFrame() writes header + payload atomically to the SPSC ring (all-or-nothing, no partial writes).\nreadFrame() reads header first, validates payloadBytes, then reads payload. Returns IPC_ERR_RING_FULL if ring has no space.",
      "originalText": "writeFrame() writes header + payload atomically to the SPSC ring (all-or-nothing, no partial writes).\nreadFrame() reads header first, validates payloadBytes, then reads payload. Returns IPC_ERR_RING_FULL if ring has no space.",
      "autoResize": true, "fontSize": 12, "fontFamily": 2, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "ring_note", "lineHeight": 1.25
    }
  ],
