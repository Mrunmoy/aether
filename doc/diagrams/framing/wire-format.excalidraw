    },
    {
      "id": "tf_flags_detail", "type": "text", "x": 65, "y": 208, "width": 290, "height": 105,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "aAa", "roundness": null,
      "seed": 11003, "version": 1, "versionNonce": 11004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "flags byte:\n  0x01  FRAME_REQUEST\n  0x02  FRAME_RESPONSE\n  0x04  FRAME_NOTIFY\n\nExactly one bit set per frame.\nDetermines dispatch path.",
      "originalText": "flags byte:\n  0x01  FRAME_REQUEST\n  0x02  FRAME_RESPONSE\n  0x04  FRAME_NOTIFY\n\nExactly one bit set per frame.\nDetermines dispatch path.",
      "autoResize": true, "fontSize": 12, "fontFamily": 3, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "flags_detail", "lineHeight": 1.25
    },

    {
      "id": "aux_detail", "type": "rectangle", "x": 400, "y": 200, "width": 400, "height": 120,
      "angle": 0, "strokeColor": "#c92a2a", "backgroundColor": "#ffe3e3",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "aB",
      "roundness": {"type": 3}, "seed": 12001, "version": 1, "versionNonce": 12002,
      "isDeleted": false, "boundElements": [{"id": "tf_aux_detail", "type": "text"}],
      "updated": 1774700000000, "link": null, "locked": false
    },
    {
      "id": "tf_aux_detail", "type": "text", "x": 405, "y": 208, "width": 390, "height": 105,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0,
      "opacity": 100, "groupIds": [], "frameId": null, "index": "aBa", "roundness": null,
      "seed": 12003, "version": 1, "versionNonce": 12004, "isDeleted": false,
      "boundElements": null, "updated": 1774700000000, "link": null, "locked": false,
      "text": "aux field (uint32, reinterpreted as int32 for status):\n  REQUEST:   0 (unused)\n  RESPONSE:  return value from handler\n             0 = IPC_SUCCESS\n             negative = framework error (IPC_ERR_*)\n             positive = app-defined error\n  NOTIFY:    0 (unused)",
      "originalText": "aux field (uint32, reinterpreted as int32 for status):\n  REQUEST:   0 (unused)\n  RESPONSE:  return value from handler\n             0 = IPC_SUCCESS\n             negative = framework error (IPC_ERR_*)\n             positive = app-defined error\n  NOTIFY:    0 (unused)",
      "autoResize": true, "fontSize": 12, "fontFamily": 3, "textAlign": "left",
      "verticalAlign": "middle", "containerId": "aux_detail", "lineHeight": 1.25
    },

    {
      "id": "payload_box", "type": "rectangle", "x": 40, "y": 370, "width": 780, "height": 80,
